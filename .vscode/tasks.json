{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build CoderPad All",
            "type": "shell",
            "command": "mkdir -p ${workspaceFolder}/questions_artifacts/coderpad_rendering && g++ -std=c++17 -g -I${workspaceFolder}/include ${workspaceFolder}/questions/coderpad_rendering/CoderPad_All.cpp -o ${workspaceFolder}/questions_artifacts/coderpad_rendering/coderpad_all",
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        },
        {
            "label": "Build active C++ file (MSVC)",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}\\scripts\\build_active_msvc.ps1",
                "-WorkspaceFolder",
                "${workspaceFolder}",
                "-FilePath",
                "${file}",
                "-FileDir",
                "${fileDirname}",
                "-FileBaseNameNoExtension",
                "${fileBasenameNoExtension}"
            ],
            "problemMatcher": [
                "$msCompile"
            ],
            "group": "build"
        }
    ]
}
