{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build active C++ file (MSVC)",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}\\scripts\\build_active_msvc.ps1",
                "-WorkspaceFolder",
                "${workspaceFolder}",
                "-FilePath",
                "${file}",
                "-FileDir",
                "${fileDirname}",
                "-FileBaseNameNoExtension",
                "${fileBasenameNoExtension}"
            ],
            "problemMatcher": [
                "$msCompile"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        }
    ]
}
